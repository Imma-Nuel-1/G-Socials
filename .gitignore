# ---- Build Outputs ----
dist/
build/
.vite/
*.tsbuildinfo

# ---- Uploads ----
server/uploads/

# ---- Database ----
*.sqlite
*.db

# ---- Logs ----
logs/
*.log

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editor ----
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Prisma ----
# Keep schema and migrations; ignore generated client if desired
# prisma/client/

# ---- Misc ----
.cache/
coverage/
